# ============================================
# UGI Education Program - Environment Variables
# ============================================
# 이 파일을 .env.local로 복사하고 실제 값으로 채워주세요.
# cp .env.example .env.local (Linux/Mac)
# copy .env.example .env.local (Windows)

# ============================================
# Firebase Client SDK 설정 (필수)
# ============================================
# Firebase Console > 프로젝트 설정 > 일반 > 앱에서 확인 가능
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# ============================================
# Firebase Admin SDK 설정 (필수)
# ============================================
# Firebase Console > 프로젝트 설정 > 서비스 계정에서 생성
# 또는 환경 변수 대신 secret/ 디렉토리에 serviceAccountKey.json 파일 배치 가능
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"

# 또는 다음 변수명 사용 가능 (호환성)
# FIREBASE_ADMIN_PROJECT_ID=your_project_id
# FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com
# FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"

# ============================================
# Firebase Realtime Database (선택사항)
# ============================================
# Realtime Database를 사용하는 경우에만 설정
# FIREBASE_DATABASE_URL=https://your_project_id-default-rtdb.asia-northeast3.firebasedatabase.app
# NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://your_project_id-default-rtdb.asia-northeast3.firebasedatabase.app

# ============================================
# OpenAI API (선택사항 - CPX 기능 사용 시)
# ============================================
# CPX (환자 병력청취 훈련) 기능을 사용하는 경우에만 필요
OPENAI_API_KEY=sk-your_openai_api_key_here

# ============================================
# Python Cloud Run 서비스 (선택사항 - EMT 분석 사용 시)
# ============================================
# EMT 비디오 분석 기능을 사용하는 경우에만 필요
PYTHON_CLOUD_RUN_URL=https://your-service-url.asia-northeast3.run.app
# 또는
# EMT_ANALYSIS_SERVICE_URL=https://your-service-url.asia-northeast3.run.app

# ============================================
# Gmail SMTP 설정 (선택사항 - 이메일 전송 기능 사용 시)
# ============================================
# 강사에게 이메일을 전송하는 기능을 사용하는 경우에만 필요
# Gmail 앱 비밀번호를 생성해야 합니다: https://myaccount.google.com/apppasswords
# 로컬: .env.local 에 설정
# Firebase 배포: .env.production 또는 .env.amcgi-bulletin 에 설정 (배포 시 함께 사용됨, Firebase Console에는 별도 입력 없음)
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_app_password_here

# ============================================
# Cleanup 작업 보안 토큰 (선택사항)
# ============================================
# Cloud Scheduler에서 cleanup 작업을 보호하려는 경우 설정
# CLEANUP_SECRET_TOKEN=your_secret_token_here
